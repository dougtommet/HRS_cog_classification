INPUT INSTRUCTIONS

  TITLE:
  vdori - Orientation to time

  vdlfl1 - Animal naming

  vdlfl2 - Scissors & cactus

  vdlfl3 - President & vice-president

  vdcount - Count backwards from 20

  vdsevens - Serial sevens

  vdwdimm - Immediate word recall

  vdwddel - Delayed word recall

  vdexf7 - Number series

  DATA:
  FILE = "model1a_a46efea7995301c55172365a036401e3.dat";
  VARIABLE:
  NAMES = mplusid HCAP16WGTR0 STRATUM SECU_mplus vdori vdlfl1z vdlfl2 vdlfl3 vdwddelz
       vdexf7z vdsevens vdcount;
   MISSING=.;
   categorical = vdori  vdlfl2 vdlfl3 vdsevens vdcount; idvariable = mplusid;
  weight = HCAP16WGTR0; stratification = STRATUM; cluster = SECU_mplus;
  ANALYSIS:
  estimator = mlr; COVERAGE=0; link=PROBIT;
  TYPE = complex;
  MODEL:
  f by vdori* vdlfl1z vdlfl2 vdlfl3 vdwddelz vdexf7z vdsevens vdcount;
    f @1;
  OUTPUT:
  standardized;
  SAVEDATA:
  H5RESULTS = model1a.h5;



