INPUT INSTRUCTIONS

  TITLE:
  x1-x3: age splines
    x4: female
    x5: black
    x6: hispanic
    x7: school years
  DATA:
  FILE = "pmm_hcap_103_jorm_65d87be91693351096bf75742f5391f5.dat";
  VARIABLE:
  NAMES = id vs1hcapdxeap HCAP16WGTR STRATUM SECU_mplus nPG014 nPG021 nPG023 nPG030
       nPG040 nPG041 nPG044 nPG047 nPG050 nPG059 jorm;
   MISSING=.;
   categorical =  nPG014 nPG021
     nPG023 nPG030  nPG040 nPG041 nPG044 nPG047 nPG050 nPG059;
  idvariable = id;
  classes = cg (3);
  knownclass = cg  (vs1hcapdxeap = 1 vs1hcapdxeap = 2 vs1hcapdxeap = 3);
  weight = HCAP16WGTR; stratification = STRATUM; cluster = SECU_mplus;
  ANALYSIS:
  estimator = mlr;
  ALGORITHM=INTEGRATION;
  starts = 80;
  processors = 12;
  TYPE = complex mixture;
  MODEL:
  %OVERALL%

     %cg#2%
     [nPG014$1 nPG021$1 nPG023$1 nPG030$1 nPG040$1
      nPG041$1 nPG044$1 nPG047$1 nPG050$1 nPG059$1
